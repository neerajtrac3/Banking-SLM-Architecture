{
  "vocab_name": "BankingSLM_Tokenizer_V1",
  "version": "1.0.0",
  "description": "Domain-specific tokenizer vocabulary for Banking Small Language Model (SLM). Includes ISO 20022 fields, payment codes, regulatory terms, legacy system keywords, and banking ontology tokens.",
